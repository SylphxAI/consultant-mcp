#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TS_ENTRY="$ROOT/dist/server.js"

resolve_rust_bin() {
	if [[ -n "${CONSULTANT_MCP_RUST_BIN:-}" && -x "${CONSULTANT_MCP_RUST_BIN}" ]]; then
		printf '%s\n' "${CONSULTANT_MCP_RUST_BIN}"
		return 0
	fi

	for candidate in \
		"$ROOT/bin/native/consultant-mcp-server" \
		"$ROOT/target/release/consultant-mcp-server" \
		"$ROOT/target/debug/consultant-mcp-server"; do
		if [[ -x "$candidate" ]]; then
			printf '%s\n' "$candidate"
			return 0
		fi
	done

	return 1
}

use_ts_transport() {
	[[ "${CONSULTANT_MCP_TRANSPORT:-}" == "ts" ]] || [[ "${1:-}" == "ts" ]]
}

if use_ts_transport "$@"; then
	if [[ "${1:-}" == "ts" ]]; then
		shift
	fi
	exec node "$TS_ENTRY" "$@"
fi

if bin="$(resolve_rust_bin)"; then
	exec "$bin" "$@"
fi

echo "[sylphx-consultant-mcp] Rust MCP server (rmcp) is not built. Run: npm run build:rust" >&2
exit 1