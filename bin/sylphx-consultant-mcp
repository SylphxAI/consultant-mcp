#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

resolve_rust_bin() {
	if [[ -n "${CONSULTANT_MCP_RUST_BIN:-}" && -x "${CONSULTANT_MCP_RUST_BIN}" ]]; then
		printf '%s\n' "${CONSULTANT_MCP_RUST_BIN}"
		return 0
	fi

	for candidate in \
		"$ROOT/bin/native/consultant-mcp-server" \
		"$ROOT/target/release/consultant-mcp-server" \
		"$ROOT/target/debug/consultant-mcp-server"; do
		if [[ -x "$candidate" ]]; then
			printf '%s\n' "$candidate"
			return 0
		fi
	done

	return 1
}

resolve_transport() {
	if [[ -n "${CONSULTANT_MCP_TRANSPORT:-}" ]]; then
		printf '%s\n' "${CONSULTANT_MCP_TRANSPORT}"
		return 0
	fi
	if [[ -n "${MCP_TRANSPORT:-}" ]]; then
		printf '%s\n' "${MCP_TRANSPORT}"
		return 0
	fi
	printf '%s\n' "stdio"
}

if bin="$(resolve_rust_bin)"; then
	transport="$(resolve_transport)"
	if [[ "$transport" == "http" ]]; then
		export MCP_TRANSPORT=http
		export CONSULTANT_MCP_TRANSPORT=http
	fi
	exec "$bin" "$@"
fi

echo "[sylphx-consultant-mcp] Prebuilt Rust binary not found at bin/native/consultant-mcp-server." >&2
echo "[sylphx-consultant-mcp] From npm: reinstall @sylphx/consultant-mcp. From source: npm run build:rust" >&2
exit 1