{
  "corpusVersion": 1,
  "transportContractCases": [
    {
      "id": "transport-default-stdio",
      "env": {},
      "expect": { "transport": "stdio" }
    },
    {
      "id": "transport-mcp-http",
      "env": { "MCP_TRANSPORT": "http" },
      "expect": { "transport": "http" }
    },
    {
      "id": "transport-consultant-http",
      "env": { "CONSULTANT_MCP_TRANSPORT": "http" },
      "expect": { "transport": "http" }
    },
    {
      "id": "transport-consultant-precedence",
      "env": {
        "CONSULTANT_MCP_TRANSPORT": "stdio",
        "MCP_TRANSPORT": "http"
      },
      "expect": { "transport": "stdio" }
    }
  ],
  "surfaceContractCases": [
    {
      "id": "surface-bin-rmcp",
      "surface": "bin",
      "markers": ["resolve_rust_bin", "resolve_transport", "MCP_TRANSPORT=http"]
    },
    {
      "id": "surface-stdio-rmcp",
      "surface": "stdio",
      "markers": ["stdio_transport::serve_stdio", "http_transport::transport_from_env"]
    },
    {
      "id": "surface-stdio-module-rmcp",
      "surface": "stdioModule",
      "markers": ["transport::stdio", "serve_stdio"]
    },
    {
      "id": "surface-http-rmcp",
      "surface": "http",
      "markers": ["StreamableHttpService", "health_check", "serve_http"]
    }
  ],
