{
  "name": "@sylphx/consultant-mcp",
  "version": "0.1.1",
  "description": "Beta MCP server for typed SOTA consultation, model fan-out, and judge synthesis for autonomous agents.",
  "type": "module",
  "packageManager": "npm@10.9.8",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "sylphx-consultant-mcp": "./bin/sylphx-consultant-mcp"
  },
  "files": [
    "bin",
    "bin/native",
    "dist",
    "docs",
    "examples",
    "README.md",
    "REPORT.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json && chmod +x dist/server.js",
    "build:rust": "cargo build --release -p consultant-core -p consultant-mcp-server && tsx scripts/stage-rust-mcp.ts",
    "check:native-packaging": "bash scripts/check-native-packaging.sh",
    "prepublishOnly": "npm run build:rust",
    "test:rust": "cargo test -p consultant-core --lib && cargo test -p consultant-mcp-server",
    "test:parity": "vitest run test/parity.test.ts && cargo test -p consultant-core parity -- --nocapture",
    "test:http-transport": "vitest run test/integration/http-transport.test.ts",
    "check:no-ts-http-backend": "bash scripts/check-no-ts-http-backend.sh",
    "check:no-ts-stdio-backend": "bash scripts/check-no-ts-stdio-backend.sh",
    "check:no-ts-tools-backend": "bash scripts/check-no-ts-tools-backend.sh",
    "check:ts-adapter-deleted": "bash scripts/check-ts-adapter-deletion-ready.sh",
    "test": "vitest run src test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:beta": "npm run check:native-packaging",
    "clean": "rm -rf dist *.tgz target bin/native",
    "verify": "npm run typecheck && npm test && npm run build && npm run test:rust && npm run test:parity && npm run test:http-transport && npm run pack:beta",
    "test:project-control": "node --test test/project-control.node-test.mjs",
    "groundatlas:fleet": "npm exec --yes --package groundatlas@0.1.3 -- ga fleet . --out .groundatlas-pilot --require-atlas --strict --json",
    "lint:fix": "biome check --write .",
    "differential": "bash scripts/run-consultant-mcp-differential.sh"
  },
  "keywords": [
    "mcp",
    "consultant",
    "agents",
    "llm",
    "deliberation",
    "sylphx"
  ],
  "author": "Sylphx",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9",
    "@biomejs/biome": "^2.3.12",
    "@sylphx/biome-config": "^0.4.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SylphxAI/consultant-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/SylphxAI/consultant-mcp/issues"
  },
  "homepage": "https://github.com/SylphxAI/consultant-mcp#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
